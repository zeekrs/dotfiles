# 系统级复制粘贴
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard

# 这里通过发送 tmux 前缀 Ctrl-Space (\x00) + 对应按键来工作

# 先解绑容易和 Ghostty 默认行为冲突的 super 组合
keybind = super+n=unbind
keybind = super+shift+n=unbind
keybind = super+t=unbind
keybind = super+w=unbind
keybind = super+shift+w=unbind
keybind = super+r=unbind
keybind = super+shift+r=unbind
keybind = super+bracket_left=unbind
keybind = super+bracket_right=unbind
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+backquote=unbind
keybind = super+ctrl+backquote=unbind
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind

# tmux new window
keybind = super+t=text:\x00c

# tmux new session
keybind = super+n=text:\x00\x03

# 新开一个 Ghostty 窗口（会按全局 command 进入 tmux）
keybind = super+shift+n=new_window

# tmux split window horizontal / vertical
keybind = super+d=text:\x00|
keybind = super+shift+d=text:\x00\\

# tmux close pane / close window
keybind = super+w=text:\x00x
keybind = super+shift+w=text:\x00X

# tmux select window 1-9
# 先解绑 Ghostty 默认的 tab 切换，再改成发给 tmux
keybind = super+digit_1=unbind
keybind = super+digit_2=unbind
keybind = super+digit_3=unbind
keybind = super+digit_4=unbind
keybind = super+digit_5=unbind
keybind = super+digit_6=unbind
keybind = super+digit_7=unbind
keybind = super+digit_8=unbind
keybind = super+digit_9=unbind
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind
keybind = super+9=unbind
keybind = super+1=text:\x001
keybind = super+2=text:\x002
keybind = super+3=text:\x003
keybind = super+4=text:\x004
keybind = super+5=text:\x005
keybind = super+6=text:\x006
keybind = super+7=text:\x007
keybind = super+8=text:\x008
keybind = super+9=text:\x009

# tmux rename window / session
keybind = super+r=text:\x00r
keybind = super+shift+r=text:\x00R

# tmux previous / next / last window
keybind = super+[=text:\x00[
keybind = super+]=text:\x00]
keybind = super+backquote=text:\x00\x09

# 保留你现有的 Vim/tmux 特殊发送键
keybind = super+s=text:\x1b[1;6P
keybind = ctrl+m=text:\x1b[1;6Q
keybind = ctrl+i=text:\x1b[1;6R
keybind = ctrl+equal=text:\x1b[1;6S
