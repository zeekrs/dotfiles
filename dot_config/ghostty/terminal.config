# 行为与启动
shell-integration = detect
copy-on-select = clipboard
macos-option-as-alt = true
confirm-close-surface = false

window-padding-x = 8
window-padding-y = 8
macos-window-buttons = hidden
macos-titlebar-style = hidden

# 保持 Ghostty 自己的 TERM；进入 tmux 后再由 tmux 管理 TERM
# 冷启动后的第一个终端窗口进入 tmux；之后的新窗口保持普通 shell。
# 首窗显式走 fish --login，再由 fish exec tmux。
command = /opt/homebrew/bin/fish --login
initial-command = shell:/opt/homebrew/bin/fish --login -c 'exec tmux new-session -A -D -s main'

# 给一点额外滚动缓冲，纯 Ghostty surface 时更顺手
scrollback-limit = 100000
