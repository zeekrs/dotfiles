{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		"sisyphus": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"hephaestus": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"oracle": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"explore": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.5",
			"variant": "medium",
			"fallback_models": [
				{
					"model": "openai/gpt-5-nano"
				}
			]
		},
		"prometheus": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"metis": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"momus": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"atlas": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"sisyphus-junior": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"librarian": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		}
	},
	"categories": {
		"visual-engineering": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"ultrabrain": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"deep": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"quick": {
			"model": "openai/gpt-5.5-fast"
		},
		"unspecified-low": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"unspecified-high": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"writing": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"artistry": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		}
	},
	"git_master": {
		"commit_footer": true,
		"include_co_authored_by": true,
		"git_env_prefix": "GIT_MASTER=1"
	},
	"tmux": {
		"enabled": true,
		"layout": "main-vertical",
		"main_pane_size": 60,
		"main_pane_min_width": 120,
		"agent_pane_min_width": 40,
		"isolation": "inline"
	}
}
